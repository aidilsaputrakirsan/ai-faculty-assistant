# =====================================================================
# AI Faculty Assistant - Frontend environment variables
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in the values.
# ONLY put PUBLIC (anon) values here. These are exposed in the browser.
# NEVER put the Groq API key or the Supabase service_role key here.
# =====================================================================

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (public) key. Safe to expose to the browser; RLS protects data.
VITE_SUPABASE_ANON_KEY=

# Base path for the built site.
# - Local dev / user page / custom domain:  /
# - GitHub project page:                    /<your-repo-name>/
VITE_BASE_PATH=/

# ---------------------------------------------------------------------
# The following secrets are NOT used by the frontend. They are configured
# as Supabase Edge Function secrets (see README "Setup Groq API").
#   GROQ_API_KEY          -> supabase secrets set GROQ_API_KEY=...
#   GROQ_MODEL            -> optional, defaults to llama-3.3-70b-versatile
#   SUPABASE_SERVICE_ROLE_KEY -> injected automatically into functions
# ---------------------------------------------------------------------
